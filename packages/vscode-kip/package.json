{
  "name": "vscode-kip",
  "displayName": "KIP Language",
  "description": "Language support for KIP (Knowledge Interaction Protocol): syntax highlighting, formatting, diagnostics, and code folding for .kip files",
  "version": "0.2.0",
  "publisher": "ldclabs",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ldclabs/KIP",
    "directory": "packages/vscode-kip"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Formatters"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "kip",
        "aliases": [
          "KIP",
          "kip"
        ],
        "extensions": [
          ".kip"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "kip",
        "scopeName": "source.kip",
        "path": "./syntaxes/kip.tmLanguage.json"
      }
    ]
  },
  "scripts": {
    "build": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --sourcemap",
    "watch": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --sourcemap --watch",
    "package": "vsce package --no-dependencies",
    "lint": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.28.0",
    "typescript": "^6.0.0"
  },
  "dependencies": {
    "@ldclabs/kip-lang": "workspace:*"
  }
}